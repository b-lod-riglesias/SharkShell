# SharkShell - Configuración de despliegue (NUNCA copiar secretos reales)

# Imagen
SHARKSHELL_IMAGE_TAG=latest
SHARKSHELL_PORT=8081
# Si quieres acceso LAN directa, usa 0.0.0.0 (más inseguro, mejor vía Caddy+TLS)
SHARKSHELL_BIND_ADDRESS=127.0.0.1
COMPOSE_PORT=8081

# ===== Base de datos (PostgreSQL externo) =====
# Nombre del servicio en compose: sharkshell-postgres
DB_HOST=sharkshell-postgres
DB_PORT=5432
DB_USER=sharkshell
DB_PASSWORD=CAMBIA_ESTO_POR_PW_LONGA
DB_NAME=sharkshell

# ===== Seguridad =====
# 64 caracteres hex (32 bytes) para AES-256-GCM
ENCRYPTION_KEY=CAMBIA_ESTO_POR_HEX_64
# Secreto JWT fuerte (mínimo 64 chars). Puedes usar base64 o hex.
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_LARGO_Y_ALEATORIO

# ===== Proxy / dominio =====
SHARKSHELL_DOMAIN=sharkshell.midominio.com
LETSENCRYPT_EMAIL=admin@midominio.com

# ===== Ajustes operativos =====
BACKUP_RETENTION_DAYS=30
COMPOSE_PROJECT_NAME=sharkshell
